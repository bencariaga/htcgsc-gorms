{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/framework": "v13.0.0 as 12.99.99",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^3.7.14",
        "maatwebsite/excel": "^3.1.68",
        "opcodesio/log-viewer": "^3.21",
        "san103/php-holiday-api": "^1.3",
        "staudenmeir/belongs-to-through": "^2.18",
        "staudenmeir/eloquent-has-many-deep": "^1.22",
        "staudenmeir/laravel-adjacency-list": "^1.26.1",
        "staudenmeir/eloquent-param-limit-fix-x-laravel-adjacency-list": "^1.4",
        "staudenmeir/laravel-cte": "^1.13.0",
        "staudenmeir/laravel-merged-relations": "^1.11"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "beyondcode/laravel-query-detector": "^2.2",
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.2.6",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.21",
        "simplesoftwareio/simple-qrcode": "4.2.0",
        "spatie/browsershot": "5.2.3",
        "spatie/image": "3.9.1",
        "spatie/laravel-data": "4.22.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Staudenmeir\\EloquentEagerLimit\\": "app/Support/EagerLimit/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "php artisan key:generate --ansi"
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}